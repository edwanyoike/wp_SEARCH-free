{
    "name": "ozulabs/turbo-search-for-woocommerce",
    "description": "High-performance WooCommerce search using native FULLTEXT indexing.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "version": "1.0.0",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit",
        "coverage": [
            "phpunit --coverage-clover=.phpunit.cache/clover.xml --coverage-text",
            "@php tests/phpunit/check-coverage.php .phpunit.cache/clover.xml 85"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
